# ===========================================================================
# RehabBot — environment variable template
# Copy this file to ".env" and fill in real values. NEVER commit a real .env.
# Each variable is documented with the member/module that owns it.
# ===========================================================================

# --- Database (Member 5 / used by Member 2) --------------------------------
# SQLAlchemy async connection string. "+psycopg" selects the psycopg v3 driver.
# Local dev:  postgresql+psycopg://postgres:rehabbot@localhost:5432/rehabbot
# Docker:     postgresql+psycopg://postgres:rehabbot@postgres:5432/rehabbot
DATABASE_URL=postgresql+psycopg://postgres:rehabbot@localhost:5432/rehabbot

# --- Sessions (Member 2) ---------------------------------------------------
# Sessions expire automatically after this many days (spec requires 21).
SESSION_EXPIRATION_DAYS=21

# --- LLM / Ollama (Member 4) -----------------------------------------------
# Local Ollama model. qwen3.5:9b-q4_K_M = 9B params, 4-bit Q4_K_M (~6.6 GB).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b-q4_K_M
# Disable Qwen3 "thinking" for faster replies (true = slower but more reasoning).
OLLAMA_THINK=false
OLLAMA_NUM_PREDICT=1024

# --- MCP server (Member 3) -------------------------------------------------
# Address of the FastMCP server exposing the scraping tools.
MCP_BASE_URL=http://localhost:8001

# --- MCP scraping (Member 3) ------------------------------------------------
SCRAPING_RATE_LIMIT_SECONDS=2

# --- Frontend (Member 1) ---------------------------------------------------
# Base URLs the Nuxt app uses to reach the backend (REST + WebSocket).
NUXT_PUBLIC_API_BASE=http://localhost:8000
NUXT_PUBLIC_WS_BASE=ws://localhost:8000

# --- CORS (Member 2) -------------------------------------------------------
# Comma-free JSON-style list is handled in code; for the backend we allow the
# Nuxt dev origin by default. (Set in code default; override here if needed.)
# CORS_ORIGINS=["http://localhost:3000"]
